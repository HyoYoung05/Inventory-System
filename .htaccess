Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI} !^/inventory-system-groupings/public/ [NC]

    RewriteCond %{DOCUMENT_ROOT}/inventory-system-groupings/public/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/inventory-system-groupings/public/$1 -d
    RewriteRule ^(.*)$ public/$1 [L]

    RewriteRule ^$ public/index.php [L]
    RewriteRule ^(.+)$ public/index.php/$1 [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    DirectoryIndex index.php
</IfModule>
